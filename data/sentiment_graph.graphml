<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd"><key id="d2" for="edge" attr.name="label" attr.type="string"/>
<key id="d1" for="edge" attr.name="weight" attr.type="double"/>
<key id="d0" for="node" attr.name="weight" attr.type="double"/>
<graph edgedefault="directed"><node id="FED">
  <data key="d0">1.0</data>
</node>
<node id="USD">
  <data key="d0">1.0</data>
</node>
<node id="NFP">
  <data key="d0">1.0</data>
</node>
<node id="ECB">
  <data key="d0">1.0</data>
</node>
<node id="EUR">
  <data key="d0">1.0</data>
</node>
<edge source="FED" target="USD">
  <data key="d1">3.2</data>
  <data key="d2">strengthens</data>
</edge>
<edge source="NFP" target="FED">
  <data key="d1">2.4</data>
  <data key="d2">forces_hike</data>
</edge>
<edge source="ECB" target="EUR">
  <data key="d1">1.6</data>
  <data key="d2">weakens</data>
</edge>
</graph></graphml>