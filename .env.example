# EuroScope Configuration
# Copy this to .env and fill in your values

# LLM Provider (NVIDIA API DeepSeek V4)
EUROSCOPE_LLM_API_KEY=your-nvidia-api-key-here
EUROSCOPE_LLM_API_BASE=https://integrate.api.nvidia.com/v1
EUROSCOPE_LLM_MODEL=deepseek-ai/deepseek-v4-flash
EUROSCOPE_LLM_FALLBACK_API_KEY=

# Telegram Bot
EUROSCOPE_TELEGRAM_TOKEN=your-telegram-bot-token
EUROSCOPE_TELEGRAM_ALLOWED_USERS=your-telegram-user-id
EUROSCOPE_TELEGRAM_WEB_APP_URL=https://your-mini-app-link.vercel.app/

# News
# Using DuckDuckGo Search (no API key required)

# Alpha Vantage (optional, for additional data)
EUROSCOPE_ALPHAVANTAGE_KEY=

# Logging
EUROSCOPE_LOG_LEVEL=INFO

# Rate limiting (protects API costs and VPS stability)
EUROSCOPE_RATE_LIMIT_REQUESTS=5
EUROSCOPE_RATE_LIMIT_WINDOW_MINUTES=1

# Vector Memory cleanup
EUROSCOPE_VECTOR_MEMORY_TTL_DAYS=30

# Admin override
EUROSCOPE_ADMIN_CHAT_IDS=

# Proactive Intelligence (autonomous market monitoring)
EUROSCOPE_PROACTIVE_CHAT_IDS=your-chat-id
EUROSCOPE_PROACTIVE_INTERVAL_MINUTES=30
EUROSCOPE_PROACTIVE_QUIET_HOURS=22-6
EUROSCOPE_PROACTIVE_DISABLE_WEEKENDS=1

# Safety Guardrails
EUROSCOPE_SAFETY_NEWS_BLOCK_MINUTES=30
EUROSCOPE_SAFETY_ASIAN_MIN_CONFIDENCE=0.75
EUROSCOPE_SAFETY_VOLATILITY_STOP_MIN=25
