# EuroScope Configuration
# Copy this to .env and fill in your values

# LLM Provider (DeepSeek recommended)
EUROSCOPE_LLM_API_KEY=your-deepseek-api-key
EUROSCOPE_LLM_API_BASE=https://api.deepseek.com
EUROSCOPE_LLM_MODEL=deepseek-chat

# Telegram Bot
EUROSCOPE_TELEGRAM_TOKEN=your-telegram-bot-token
EUROSCOPE_TELEGRAM_ALLOWED_USERS=your-telegram-user-id

# Brave Search API (for news)
EUROSCOPE_BRAVE_API_KEY=your-brave-api-key

# Alpha Vantage (optional, for additional data)
EUROSCOPE_ALPHAVANTAGE_KEY=

# Logging
EUROSCOPE_LOG_LEVEL=INFO
